<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>عرض سعر</title>
    <style>
      @page {
        size: A4;
        margin: 28mm 14mm 22mm;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        direction: rtl;
        text-align: right;
        color: #1f2937;
        background: #ffffff;
        font-family: "Tahoma", "Segoe UI", Arial, sans-serif;
        font-size: 12px;
        line-height: 1.7;
      }

      .page {
        padding: 0;
      }

      .meta-grid,
      .info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px 14px;
      }

      .section {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 12px;
        margin-bottom: 14px;
      }

      .section.keep-together {
        break-inside: avoid-page;
        page-break-inside: avoid;
      }

      .section-title {
        margin: 0 0 10px;
        font-size: 13px;
        font-weight: 700;
        color: #111827;
      }

      .field {
        display: flex;
        gap: 6px;
        align-items: baseline;
      }

      .field-label {
        min-width: 88px;
        color: #6b7280;
        font-weight: 600;
      }

      .field-value {
        color: #111827;
        word-break: break-word;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      thead {
        display: table-header-group;
      }

      th,
      td {
        border: 1px solid #e5e7eb;
        padding: 5px 6px;
        vertical-align: top;
      }

      th {
        background: #f8fafc;
        color: #374151;
        font-weight: 700;
      }

      .summary-row {
        background: #fff7ed !important;
        font-weight: 700;
      }

      .item-cell-title {
        font-weight: 700;
        color: #111827;
        margin-bottom: 2px;
      }

      .item-cell-note {
        margin-top: 2px;
        color: #6b7280;
        font-size: 11px;
        white-space: pre-wrap;
      }

      .item-cell-empty {
        color: #9ca3af;
      }

      .price-cell {
        white-space: nowrap;
      }

      .summary-secondary-title {
        font-weight: 700;
        color: #111827;
      }

      .muted {
        color: #6b7280;
      }

      .totals {
        width: 320px;
        margin-inline-start: auto;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        page-break-inside: avoid;
      }

      .totals-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 12px;
        border-bottom: 1px solid #e5e7eb;
      }

      .totals-row:last-child {
        border-bottom: 0;
      }

      .totals-row.total {
        background: #111827;
        color: #fff;
        font-weight: 700;
      }

      .notes {
        white-space: pre-wrap;
      }

      .text-left {
        text-align: left;
      }

      .text-center {
        text-align: center;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <section class="section keep-together">
        <div class="meta-grid">
          <div class="field">
            <div class="field-label">رقم العرض</div>
            <div class="field-value"><%= helpers.displayText(data.quotation.quotationNumber) %></div>
          </div>
          <div class="field">
            <div class="field-label">الحالة</div>
            <div class="field-value"><%= helpers.displayText(data.quotation.status) %></div>
          </div>
          <div class="field">
            <div class="field-label">تاريخ الإصدار</div>
            <div class="field-value"><%= helpers.formatDate(data.quotation.issueDate) %></div>
          </div>
          <div class="field">
            <div class="field-label">صالح حتى</div>
            <div class="field-value"><%= helpers.formatDate(data.quotation.validUntil) %></div>
          </div>
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">بيانات العميل والحفل</h2>
        <div class="info-grid">
          <div class="field">
            <div class="field-label">العميل</div>
            <div class="field-value"><%= helpers.displayText(data.customer.fullName) %></div>
          </div>
          <div class="field">
            <div class="field-label">الجوال 1</div>
            <div class="field-value"><%= helpers.displayText(data.customer.mobile1) %></div>
          </div>
          <div class="field">
            <div class="field-label">الجوال 2</div>
            <div class="field-value"><%= helpers.displayText(data.customer.mobile2) %></div>
          </div>
          <div class="field">
            <div class="field-label">عنوان الحفل</div>
            <div class="field-value"><%= helpers.displayText(data.event.title) %></div>
          </div>
          <div class="field">
            <div class="field-label">تاريخ الحفل</div>
            <div class="field-value"><%= helpers.formatDate(data.event.eventDate) %></div>
          </div>
          <div class="field">
            <div class="field-label">المكان</div>
            <div class="field-value"><%= helpers.displayText(data.event.venueName) %></div>
          </div>
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">بنود العرض</h2>

        <table>
          <thead>
            <tr>
              <th style="width: 46px;">م</th>
              <th>تجهيز الديكورات الداخلية</th>
              <th style="width: 140px;">السعر</th>
              <th>شركات خارجية</th>
              <th style="width: 140px;">السعر</th>
            </tr>
          </thead>
          <tbody>
            <% data.pairedItems.forEach(function(row, index) { %>
              <tr class="<%= row.serviceItem && row.serviceItem.isSummaryRow ? 'summary-row' : '' %>">
                <td class="text-center"><%= index + 1 %></td>
                <td>
                  <% if (row.serviceItem) { %>
                    <div class="item-cell-title"><%= helpers.displayText(row.serviceItem.itemName) %></div>
                    <% if (row.serviceItem.notes) { %>
                      <div class="item-cell-note"><%= helpers.displayText(row.serviceItem.notes) %></div>
                    <% } %>
                  <% } else { %>
                    <div class="item-cell-empty">-</div>
                  <% } %>
                </td>
                <td class="text-left price-cell">
                  <%= row.serviceItem ? helpers.formatMoney(row.serviceItem.totalPrice) : '-' %>
                </td>
                <td>
                  <% if (row.vendorItem) { %>
                    <div class="item-cell-title"><%= helpers.displayText(row.vendorItem.itemName) %></div>
                    <% if (row.vendorItem.notes) { %>
                      <div class="item-cell-note"><%= helpers.displayText(row.vendorItem.notes) %></div>
                    <% } %>
                  <% } else if (row.serviceItem && row.serviceItem.isSummaryRow) { %>
                    <div class="summary-secondary-title">إجمالي الشركات</div>
                  <% } else { %>
                    <div class="item-cell-empty">-</div>
                  <% } %>
                </td>
                <td class="text-left price-cell">
                  <% if (row.vendorItem) { %>
                    <%= helpers.formatMoney(row.vendorItem.totalPrice) %>
                  <% } else if (row.serviceItem && row.serviceItem.isSummaryRow) { %>
                    <%= helpers.formatMoney(data.vendorTotalAmount) %>
                  <% } else { %>
                    -
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>

      <section class="section" style="border: 0; padding: 0; margin-bottom: 0;">
        <div class="totals">
          <div class="totals-row">
            <span>الإجمالي الفرعي</span>
            <strong><%= helpers.formatMoney(data.quotation.subtotal) %></strong>
          </div>
          <div class="totals-row">
            <span>الخصم</span>
            <strong><%= helpers.formatMoney(data.quotation.discountAmount) %></strong>
          </div>
          <div class="totals-row total">
            <span>الإجمالي النهائي</span>
            <strong><%= helpers.formatMoney(data.quotation.totalAmount) %></strong>
          </div>
        </div>
      </section>

      <% if (data.quotation.notes) { %>
        <section class="section">
          <h2 class="section-title">ملاحظات</h2>
          <div class="notes"><%= data.quotation.notes %></div>
        </section>
      <% } %>

    </div>
  </body>
</html>

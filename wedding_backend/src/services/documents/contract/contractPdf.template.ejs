<!DOCTYPE html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>عقد اتفاق</title>
    <style>
      @page {
        size: A4;
        margin: 38mm 12mm 28mm;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        direction: rtl;
        text-align: right;
        color: #1f2937;
        background: #ffffff;
        font-family: "Tahoma", "Segoe UI", Arial, sans-serif;
        font-size: 11px;
        line-height: 1.5;
      }

      .page {
        padding: 0;
      }

      .section {
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 8px;
        margin-bottom: 10px;
      }

      .section.keep-together {
        break-inside: avoid-page;
        page-break-inside: avoid;
      }

      .opening-section {
        margin-bottom: 8px;
        padding: 0 2px;
      }

      .opening-list {
        margin: 0;
        padding: 0 18px 0 0;
      }

      .opening-list li {
        margin-bottom: 2px;
      }

      .opening-inline {
        display: inline-block;
        min-width: 120px;
      }

      .section-title {
        margin: 0 0 6px;
        font-size: 12px;
        font-weight: 700;
        color: #111827;
      }

      .meta-grid,
      .info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px 14px;
      }

      .field {
        display: flex;
        gap: 6px;
        align-items: baseline;
      }

      .field-label {
        min-width: 96px;
        color: #6b7280;
        font-weight: 600;
      }

      .field-value {
        color: #111827;
        word-break: break-word;
      }

      .intro {
        white-space: pre-wrap;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      thead {
        display: table-header-group;
      }

      th,
      td {
        border: 1.2px solid #b8c0cc;
        padding: 3px 4px;
        vertical-align: top;
      }

      th {
        background: #f8fafc;
        color: #374151;
        font-weight: 700;
        border-color: #9099a8;
      }

      .summary-row {
        background: #fff7ed !important;
        font-weight: 700;
      }

      .item-cell-title {
        font-weight: 700;
        color: #111827;
        margin-bottom: 1px;
      }

      .item-cell-note {
        margin-top: 1px;
        color: #6b7280;
        font-size: 9px;
        white-space: pre-wrap;
        line-height: 1.25;
      }

      .item-cell-empty {
        color: #9ca3af;
      }

      .price-cell {
        white-space: nowrap;
      }

      .summary-secondary-title {
        font-weight: 700;
        color: #111827;
      }

      .items-section {
        padding-top: 6px;
      }

      .items-table {
        font-size: 10px;
        line-height: 1.2;
      }

      .items-table th,
      .items-table td {
        padding: 2px 4px;
        border-color: #7f8898;
      }

      .page-break-before {
        break-before: page;
        page-break-before: always;
      }

      .totals {
        width: 340px;
        margin-inline-start: auto;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
      }

      .totals-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 12px;
        border-bottom: 1px solid #e5e7eb;
      }

      .totals-row:last-child {
        border-bottom: 0;
      }

      .totals-row.total {
        background: #111827;
        color: #fff;
        font-weight: 700;
      }

      .clause {
        margin-bottom: 12px;
        break-inside: avoid-page;
        page-break-inside: avoid;
      }

      .clause-title {
        margin: 0 0 6px;
        font-size: 13px;
        font-weight: 700;
        color: #111827;
      }

      .clause p {
        margin: 0 0 6px;
      }

      .definitions-table {
        margin: 8px 0 10px;
      }

      .definitions-table th,
      .definitions-table td {
        text-align: right;
      }

      .definitions-table th:nth-child(1),
      .definitions-table td:nth-child(1) {
        width: 48px;
        text-align: center;
      }

      .definitions-table th:nth-child(2),
      .definitions-table td:nth-child(2) {
        width: 150px;
      }

      .signatures {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .signature-box {
        border: 1px dashed #cbd5e1;
        border-radius: 14px;
        padding: 14px;
        min-height: 190px;
      }

      .signature-box h3 {
        margin: 0 0 12px;
        font-size: 14px;
      }

      .signature-line {
        margin-bottom: 10px;
      }

      .closing-note {
        margin-top: 10px;
        text-align: center;
        color: #374151;
        font-weight: 600;
      }

      .muted {
        color: #6b7280;
      }

      .text-left {
        text-align: left;
      }

      .text-center {
        text-align: center;
      }
    </style>
  </head>
  <body>
    <%
      const signedDate = data.contract.signedDate ? new Date(data.contract.signedDate) : null;
      const hasSignedDate = signedDate && !Number.isNaN(signedDate.getTime());
      const signedWeekday = hasSignedDate
        ? new Intl.DateTimeFormat("ar-KW", { weekday: "long" }).format(signedDate)
        : "..........";
      const signedDay = hasSignedDate
        ? String(signedDate.getDate()).padStart(2, "0")
        : "..........";
      const signedMonth = hasSignedDate
        ? new Intl.DateTimeFormat("ar-KW", { month: "long" }).format(signedDate)
        : "..........";
      const signedYear = hasSignedDate ? String(signedDate.getFullYear()) : "2026";
      const rawContractNumber = String(helpers.displayText(data.contract.contractNumber, "")).trim();
      const contractDisplayNumber = rawContractNumber && rawContractNumber !== "-"
        ? (rawContractNumber.includes("/") ? rawContractNumber : `${rawContractNumber}/${signedYear}`)
        : `...../${signedYear}`;
      const customerName = helpers.displayText(data.customer.fullName, "..................");
      const customerCivilId = helpers.displayText(data.customer.civilId, ".................................");
      const customerAddress = helpers.displayText(data.customer.address, "........................................................");
      const customerPhone = helpers.displayText(data.customer.mobile1 || data.customer.mobile2, "........................................");
    %>
    <div class="page">
      <section class="opening-section keep-together">
        <ul class="opening-list">
          <li><strong>عقد اتفاق رقم (<%= contractDisplayNumber %>)</strong></li>
          <li>أبرمت هذه الإتفاقية في هذا اليوم <span class="opening-inline"><%= signedWeekday %></span> الموافق <span class="opening-inline"><%= signedDay %></span> من شهر <span class="opening-inline"><%= signedMonth %></span> عام <%= signedYear %> بين كلاً من:</li>
          <li>أولاً: (طرف أول) <strong>شركة اي بي روزس لتجهيز وادارة الافراح وتأجير معداتها</strong> <span class="opening-inline">(شركة تضامنية)</span></li>
          <li>ثانياً: (طرف ثاني) السيدة/ <strong><%= customerName %></strong> المحترمين <span class="opening-inline">(كويتية الجنسية)</span></li>
          <li>ب.م رقم: (<%= customerCivilId %>) <span class="opening-inline">العنوان: (<%= customerAddress %>)</span></li>
          <li>رقم التليفون (<%= customerPhone %>)</li>
          <li><strong>على تجهيز وتوريد الآتي:</strong></li>
        </ul>
      </section>

      <section class="section items-section">
        <table class="items-table">
          <thead>
            <tr>
              <th style="width: 46px;">م</th>
              <th>تجهيز الديكورات الداخلية</th>
              <th style="width: 140px;">السعر</th>
              <th>شركات خارجية</th>
              <th style="width: 140px;">السعر</th>
            </tr>
          </thead>
          <tbody>
            <% data.pairedItems.forEach(function(row, index) { %>
              <tr class="<%= row.serviceItem && row.serviceItem.isSummaryRow ? 'summary-row' : '' %>">
                <td class="text-center"><%= index + 1 %></td>
                <td>
                  <% if (row.serviceItem) { %>
                    <div class="item-cell-title"><%= helpers.displayText(row.serviceItem.itemName) %></div>
                    <% if (row.serviceItem.notes) { %>
                      <div class="item-cell-note"><%= helpers.displayText(row.serviceItem.notes) %></div>
                    <% } %>
                  <% } else { %>
                    <div class="item-cell-empty">-</div>
                  <% } %>
                </td>
                <td class="text-left price-cell">
                  <%= row.serviceItem ? helpers.formatMoney(row.serviceItem.totalPrice) : '-' %>
                </td>
                <td>
                  <% if (row.vendorItem) { %>
                    <div class="item-cell-title"><%= helpers.displayText(row.vendorItem.itemName) %></div>
                    <% if (row.vendorItem.notes) { %>
                      <div class="item-cell-note"><%= helpers.displayText(row.vendorItem.notes) %></div>
                    <% } %>
                  <% } else if (row.serviceItem && row.serviceItem.isSummaryRow) { %>
                    <div class="summary-secondary-title">إجمالي الشركات</div>
                  <% } else { %>
                    <div class="item-cell-empty">-</div>
                  <% } %>
                </td>
                <td class="text-left price-cell">
                  <% if (row.vendorItem) { %>
                    <%= helpers.formatMoney(row.vendorItem.totalPrice) %>
                  <% } else if (row.serviceItem && row.serviceItem.isSummaryRow) { %>
                    <%= helpers.formatMoney(data.vendorTotalAmount) %>
                  <% } else { %>
                    -
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>

      <section class="section" style="border: 0; padding: 0;">
        <div class="totals">
          <div class="totals-row">
            <span>الإجمالي الفرعي</span>
            <strong><%= helpers.formatMoney(data.contract.subtotal) %></strong>
          </div>
          <div class="totals-row">
            <span>الخصم</span>
            <strong><%= helpers.formatMoney(data.contract.discountAmount) %></strong>
          </div>
          <div class="totals-row total">
            <span>إجمالي قيمة العقد</span>
            <strong><%= helpers.formatMoney(data.contract.totalAmount) %></strong>
          </div>
        </div>
      </section>

      <% if (data.paymentSchedules.length > 0) { %>
        <section class="section">
          <h2 class="section-title">جدول الدفعات</h2>
          <table>
            <thead>
              <tr>
                <th>الدفعة</th>
                <th style="width: 120px;">الاستحقاق</th>
                <th style="width: 120px;">المبلغ</th>
                <th style="width: 100px;">الحالة</th>
                <th>ملاحظات</th>
              </tr>
            </thead>
            <tbody>
              <% data.paymentSchedules.forEach(function(item) { %>
                <tr>
                  <td><%= helpers.displayText(item.installmentName) %></td>
                  <td><%= helpers.formatDate(item.dueDate) %></td>
                  <td class="text-left"><%= helpers.formatMoney(item.amount) %></td>
                  <td><%= helpers.displayText(item.status) %></td>
                  <td><%= helpers.displayText(item.notes) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </section>
      <% } %>

      <section class="section page-break-before">
        <h2 class="section-title">الشروط والأحكام</h2>
        <% data.clauses.forEach(function(clause) { %>
          <div class="clause">
            <h3 class="clause-title"><%= clause.title %></h3>
            <% if (clause.definitions && clause.definitions.length > 0) { %>
              <table class="definitions-table">
                <thead>
                  <tr>
                    <th>م</th>
                    <th>الكلمات</th>
                    <th>التعريف</th>
                  </tr>
                </thead>
                <tbody>
                  <% clause.definitions.forEach(function(row) { %>
                    <tr>
                      <td class="text-center"><%= row.number %></td>
                      <td><%= row.term %></td>
                      <td><%= row.definition %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
            <% clause.paragraphs.forEach(function(paragraph) { %>
              <p><%= paragraph %></p>
            <% }) %>
          </div>
        <% }) %>
      </section>

      <% if (data.contract.notes) { %>
        <section class="section keep-together">
          <h2 class="section-title">ملاحظات إضافية</h2>
          <div class="intro"><%= data.contract.notes %></div>
        </section>
      <% } %>

      <section class="section keep-together">
        <h2 class="section-title">التوقيعات</h2>
        <div class="signatures">
          <div class="signature-box">
            <h3>(الطرف الثاني)</h3>
            <div class="signature-line">الاسـم: <strong><%= helpers.displayText(data.customer.fullName) %></strong></div>
            <div class="signature-line">التاريخ: <strong><%= helpers.formatDate(data.contract.signedDate) %></strong></div>
            <div class="signature-line">الرقم المدني: <strong><%= helpers.displayText(data.customer.civilId) %></strong></div>
            <div class="signature-line" style="margin-top: 34px;">التوقيع: ____________________</div>
          </div>

          <div class="signature-box">
            <h3>(الطرف الأول)</h3>
            <div class="signature-line">الاسـم: <strong><%= helpers.displayText(data.company.name) %></strong></div>
            <div class="signature-line">التاريخ: <strong><%= helpers.formatDate(data.contract.signedDate) %></strong></div>
            <div class="signature-line" style="margin-top: 62px;">التوقيع: ____________________</div>
          </div>
        </div>
        <div class="closing-note">شكراً لتعاملكم معنا مع تمنياتنا لكم بدوام التوفيق والسعادة والخير والبركة</div>
      </section>
    </div>
  </body>
</html>

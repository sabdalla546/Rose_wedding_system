{
  "name": "wedding-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src -e ts --exec ts-node src/server.ts",
    "build": "tsc && node scripts/copy-document-assets.js",
    "start": "node dist/server.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "seed": "npm run seed:core && npm run seed:vendors && npm run seed:appointments-events",
    "seed:undo": "sequelize-cli db:seed:undo:all",
    "seed:core": "npm run seed:vendor-types && npm run seed:rbac && npm run seed:services && npm run seed:venues",
    "scan:permissions": "ts-node src/seed/scanRoutePermissions.ts",
    "seed:rbac": "ts-node src/seed/seedRbac.ts",
    "seed:vendor-types": "sequelize-cli db:seed --seed 20260404090000-seed-vendor-types.js",
    "seed:vendors": "npm run seed:vendor-types && ts-node src/seed/seedExternalVendors.ts",
    "seed:venues": "ts-node src/seed/seedVenues.ts",
    "seed:appointments-events": "ts-node src/seed/seedCustomersAppointmentsEvents.ts",
    "seed:services": "ts-node src/seed/seedServices.ts",
    "setup:dev": "npm run migrate && npm run seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dayjs": "^1.11.20",
    "dotenv": "^16.4.0",
    "ejs": "^5.0.1",
    "express": "^4.19.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.0.0",
    "i18next": "^23.0.0",
    "i18next-fs-backend": "^2.3.1",
    "i18next-http-middleware": "^3.5.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "mysql2": "^3.9.0",
    "puppeteer": "^24.40.0",
    "sequelize": "^6.37.0",
    "winston": "^3.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.15",
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
